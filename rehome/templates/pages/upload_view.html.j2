{% extends "layouts/viewer.html.j2" %}

{% set raw_url = url_for('uploads.raw', slug=upload.slug) %}

{% block title %}{{ upload.name }}{% endblock %}

{% block extra_head %}
{{ super() }}

<meta property="og:title" content="{{ upload.name }}">
{% if content is defined %}
<meta property="og:description" content="{{ content | truncate(200) }}">
{% endif %}
{% endblock %}

{% block content %}
<div class="viewer-content">
    <div class="viewer-file-header">
        <div class="viewer-file-meta">
            <span class="viewer-filename">{{ upload.name }}</span>
            <span class="viewer-sep">|</span>
            <span class="viewer-size">{{ size }}</span>
        </div>

        <div class="viewer-file-actions">
            {% if rendered is defined %}
            <a href="{{ raw_url }}" class="viewer-toggle-btn" id="viewer-toggle"
                data-language="{{ language }}">source</a>
            <span class="viewer-sep">|</span>
            {% endif %}
            <a href="{{ raw_url }}" class="viewer-raw-btn">raw</a>
            <span class="viewer-sep">|</span>
            <a href="{{ raw_url }}" download="{{ upload.name }}" class="viewer-download-btn">download</a>
        </div>
    </div>
    {% if rendered is defined %}
    <div class="viewer-markdown" id="viewer-rendered">
        {{ rendered | safe }}
    </div>
    <div class="viewer-code" id="viewer-source" hidden>
        <pre class="viewer-pre"><code class="language-{{ language }}"></code></pre>
    </div>
    {% else %}
    <div class="viewer-code">
        <pre class="viewer-pre"><code class="language-{{ language }}">{{ content }}</code></pre>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
{% if rendered is defined %}
<script src="{{ url_for('static', filename='js/viewer-toggle.js', version=meta.COMMIT) }}"></script>
{% endif %}
{% endblock %}
